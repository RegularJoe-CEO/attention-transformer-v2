#!/usr/bin/env bash
# Paste the SSH line RunPod gives you — we write scripts/runpod.env automatically.
#
#   scripts/pod-setup
#
# Use **SSH over exposed TCP** from RunPod Connect (best for scripts/pod + rsync).
# Do NOT use the :8888 Jupyter link for this workflow.

set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="$DIR/runpod.env"

echo "═══════════════════════════════════════════════════════════════"
echo " RunPod SSH setup (paste only — no typing host/port)"
echo "═══════════════════════════════════════════════════════════════"
echo ""
echo "In RunPod → your pod → Connect, copy ONE of these:"
echo "  • RECOMMENDED: \"SSH over exposed TCP\"  (root@IP -p PORT ...)"
echo "  • Or: \"SSH\" proxy line (xxxx@ssh.runpod.io -i ...)"
echo ""
echo "Paste the full line below (including 'ssh' at the start), then Enter:"
read -r PASTE

PASTE="${PASTE#ssh }"
PASTE="${PASTE#SSH }"

HOST=""
PORT=""
IDENTITY="${HOME}/.ssh/id_ed25519"
USER="root"
EXTRA=()

# shellcheck disable=SC2206
PARTS=($PASTE)
i=0
while [[ $i -lt ${#PARTS[@]} ]]; do
  p="${PARTS[$i]}"
  case "$p" in
    -p|--port)
      i=$((i + 1))
      PORT="${PARTS[$i]:-}"
      ;;
    -i|--identity|-i=*)
      if [[ "$p" == -i=* ]]; then
        IDENTITY="${p#-i=}"
      else
        i=$((i + 1))
        IDENTITY="${PARTS[$i]:-}"
      fi
      ;;
    -o)
      i=$((i + 1))
      EXTRA+=(-o "${PARTS[$i]:-}")
      ;;
    *@*)
      USER="${p%%@*}"
      HOST="${p#*@}"
      ;;
    *)
      if [[ -z "$HOST" && "$p" != -* ]]; then
        HOST="$p"
      fi
      ;;
  esac
  i=$((i + 1))
done

IDENTITY="${IDENTITY/#\~/$HOME}"

if [[ -z "$HOST" ]]; then
  echo "Could not parse host. Paste example:"
  echo "  ssh root@12.34.56.78 -p 12345 -i ~/.ssh/id_ed25519"
  exit 1
fi

cat > "$ENV_FILE" <<EOF
# Auto-generated by scripts/pod-setup — paste again if RunPod gives a new line
# Connect type: ${PORT:+TCP exposed}${PORT:-RunPod proxy}
RUNPOD_SSH_USER="${USER}"
RUNPOD_SSH_HOST="${HOST}"
RUNPOD_SSH_PORT="${PORT}"
RUNPOD_SSH_IDENTITY="${IDENTITY}"
REMOTE_DIR="/workspace/attention-transformer-v2"
CUDA_ARCH="${CUDA_ARCH:-90}"
EOF

echo ""
echo "Wrote $ENV_FILE"
echo "  user@host: ${USER}@${HOST}"
echo "  port:      ${PORT:-(default 22 / proxy)}"
echo "  key:       ${IDENTITY}"
echo ""
echo "Testing connection..."
# shellcheck source=runpod_ssh.sh
source "$DIR/runpod_ssh.sh"
if runpod_ssh "echo OK && nvidia-smi --query-gpu=name --format=csv,noheader | head -1"; then
  echo ""
  echo "Success. Next:  cd $(cd "$DIR/.." && pwd) && scripts/pod"
else
  echo ""
  echo "SSH failed. Try:"
  echo "  1) RunPod → Connect → SSH over exposed TCP (not :8888)"
  echo "  2) Settings → SSH Public Keys → add: cat ~/.ssh/id_ed25519.pub"
  echo "  3) Re-run: scripts/pod-setup"
fi